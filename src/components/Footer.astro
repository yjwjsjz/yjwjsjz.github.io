---
import { GITHUB_URL } from '../consts';

const today = new Date();
---

<footer>
	<nav class="footer-nav" aria-label="页脚导航">
		<a href="/">首页</a>
		<a href="/blog">文章</a>
		<a href="/about">关于</a>
		<a href="/rss.xml">RSS</a>
		<a href={GITHUB_URL} target="_blank" rel="noopener">GitHub</a>
	</nav>
	<p class="copyright">
		&copy; {today.getFullYear()} WuhuKaitou · 用
		<a href="https://astro.build/" target="_blank" rel="noopener">Astro</a> 构建,托管于 GitHub Pages
	</p>
</footer>
<style>
	footer {
		margin-top: 3em;
		padding: 2.2em 1em 2.6em;
		border-top: 1px solid rgb(var(--gray-light));
		text-align: center;
	}
	.footer-nav {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.4em 1.6em;
		margin-bottom: 0.9em;
	}
	.footer-nav a {
		font-size: 0.95em;
		font-weight: 600;
		color: rgb(var(--gray-dark));
		text-decoration: none;
	}
	.footer-nav a:hover {
		color: var(--accent);
	}
	.copyright {
		margin: 0;
		font-size: 0.88em;
		color: rgb(var(--gray));
	}
	.copyright a {
		color: rgb(var(--gray));
	}
	.copyright a:hover {
		color: var(--accent);
	}
</style>
