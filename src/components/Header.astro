---
import { GITHUB_URL, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav aria-label="主导航">
		<a class="brand" href="/" aria-label={SITE_TITLE}>
			<img
				src="https://github.com/yjwjsjz.png?size=80"
				alt=""
				width="34"
				height="34"
				loading="eager"
				referrerpolicy="no-referrer"
			/>
		</a>
		<div class="pill">
			<HeaderLink href="/">首页</HeaderLink>
			<HeaderLink href="/blog">文章</HeaderLink>
			<HeaderLink href="/about">关于</HeaderLink>
		</div>
		<div class="nav-right">
			<button id="theme-toggle" aria-label="切换夜间模式" title="切换夜间模式">
				<svg
					class="theme-icon-light"
					viewBox="0 0 24 24"
					aria-hidden="true"
					width="20"
					height="20"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg
				>
				<svg
					class="theme-icon-dark"
					viewBox="0 0 24 24"
					aria-hidden="true"
					width="20"
					height="20"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line
						x1="12"
						y1="21"
						x2="12"
						y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line
						x1="18.36"
						y1="18.36"
						x2="19.78"
						y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line
						x1="21"
						y1="12"
						x2="23"
						y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line
						x1="18.36"
						y1="5.64"
						x2="19.78"
						y2="4.22"></line></svg
				>
			</button>
			<a class="icon-btn" href={GITHUB_URL} target="_blank" rel="noopener">
				<span class="sr-only">我的 GitHub</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="19" height="19"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</header>
<script>
	function currentTheme(): 'light' | 'dark' {
		const explicit = document.documentElement.dataset.theme;
		if (explicit === 'light' || explicit === 'dark') return explicit;
		return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
	}
	function syncGiscusTheme(theme: string) {
		const frame = document.querySelector<HTMLIFrameElement>('iframe.giscus-frame');
		frame?.contentWindow?.postMessage(
			{ giscus: { setConfig: { theme } } },
			'https://giscus.app'
		);
	}
	// 事件委托:View Transitions 换页后按钮是新 DOM,直接绑按钮会失联
	document.addEventListener('click', (event) => {
		const target = event.target;
		if (!(target instanceof Element) || !target.closest('#theme-toggle')) return;
		const next = currentTheme() === 'dark' ? 'light' : 'dark';
		document.documentElement.dataset.theme = next;
		try {
			localStorage.setItem('theme', next);
		} catch {
			/* 无痕模式下仅本页生效 */
		}
		syncGiscusTheme(next);
	});
	// giscus 加载期间用户可能已切主题(此时 postMessage 会落空),
	// 收到它的首条消息(就绪信号)后按当前主题补对齐一次
	let giscusSynced = false;
	window.addEventListener('message', (event) => {
		if (event.origin !== 'https://giscus.app' || giscusSynced) return;
		giscusSynced = true;
		syncGiscusTheme(currentTheme());
	});
	document.addEventListener('astro:after-swap', () => {
		giscusSynced = false;
	});
</script>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 50;
		padding: 0.6em 1em;
		pointer-events: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 960px;
		margin: 0 auto;
	}
	nav > * {
		pointer-events: auto;
	}
	.brand img {
		display: block;
		border-radius: 11px;
		border: 1px solid rgba(var(--gray-light), 0.8);
	}
	.pill {
		display: flex;
		gap: 0.1em;
		padding: 0.25em 0.35em;
		border: 1px solid rgba(var(--gray-light), 0.8);
		border-radius: 999px;
		background: var(--bg-blur);
		-webkit-backdrop-filter: blur(12px) saturate(1.6);
		backdrop-filter: blur(12px) saturate(1.6);
		box-shadow: 0 4px 18px rgba(0, 0, 0, 0.08);
	}
	.pill a {
		padding: 0.32em 0.85em;
		border-radius: 999px;
		color: rgb(var(--gray-dark));
		text-decoration: none;
		font-size: 0.95em;
		transition: background-color 0.15s ease, color 0.15s ease;
	}
	.pill a:hover {
		background: rgba(var(--gray-light), 0.6);
	}
	.pill a.active {
		color: var(--accent-text, var(--accent));
		font-weight: 700;
	}
	.nav-right {
		display: flex;
		align-items: center;
		gap: 0.45em;
	}
	.icon-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 38px;
		height: 38px;
		border-radius: 50%;
		border: 1px solid rgba(var(--gray-light), 0.8);
		background: var(--bg-blur);
		-webkit-backdrop-filter: blur(12px);
		backdrop-filter: blur(12px);
		color: rgb(var(--gray-dark));
		transition: color 0.15s ease, border-color 0.15s ease;
	}
	.icon-btn:hover {
		color: var(--accent-text, var(--accent));
		border-color: rgb(var(--gray));
	}
	@media (max-width: 560px) {
		.brand {
			display: none;
		}
	}
</style>
