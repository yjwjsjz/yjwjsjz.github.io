---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { GITHUB_URL, SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { readingMinutes } from '../utils/reading-time';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const posts = allPosts.slice(0, 3);

// 站点统计(构建时算,每次部署更新)
const totalCjk = allPosts.reduce(
	(n, p) => n + (((p.body ?? '').match(/[一-鿿]/g) ?? []).length),
	0
);
const wanzi = (totalCjk / 10000).toFixed(1);
const firstPub = Math.min(...allPosts.map((p) => p.data.pubDate.valueOf()));
const days = Math.max(1, Math.ceil((Date.now() - firstPub) / 86400000));

const projects = [
	{
		name: '永劫无间数据平台',
		desc: 'QQ 机器人 + Web 双端的游戏社区平台:Steam 查号、签到积分、商城、社区论坛、管理后台,全套自研自运维。',
		href: 'https://yjwj.pro',
		hint: 'yjwj.pro',
		// 亮/暗两套主题色:亮色面(白底)用深色保对比度,暗色面用亮色
		colorLight: '#2337ff',
		colorDark: '#7c8cff',
		icon: '<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2"></rect><rect x="2" y="14" width="20" height="8" rx="2"></rect><line x1="6" y1="6" x2="6.01" y2="6"></line><line x1="6" y1="18" x2="6.01" y2="18"></line></svg>',
	},
	{
		name: '摸金战绩查询',
		desc: '永劫无间「无间镖客」模式的战绩查询独立站,照小程序 UI 复刻,段位徽章、趋势图、近期对局一应俱全。',
		href: 'https://naraka.yjwj.pro',
		hint: 'naraka.yjwj.pro',
		colorLight: '#047857',
		colorDark: '#34d399',
		icon: '<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>',
	},
	{
		name: '更多折腾',
		desc: '发卡机器人、聚合工具站、监控告警、CI 流水线……大部分轮子都在 GitHub 上慢慢攒。',
		href: GITHUB_URL,
		hint: 'GitHub',
		colorLight: '#c2410c',
		colorDark: '#ff7b54',
		icon: '<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>',
	},
];

const stacks = [
	{ label: '后端', color: '#7c8cff', items: ['Python', 'FastAPI', 'NoneBot2', 'SQLite / SQLAlchemy', 'Java'] },
	{ label: '前端', color: '#34d399', items: ['TypeScript', 'Next.js', 'Astro', 'Tailwind CSS'] },
	{ label: '运维', color: '#ff7b54', items: ['Linux', 'Caddy', 'Docker', 'GitHub Actions'] },
];

const socials = [
	{
		label: 'GitHub',
		href: GITHUB_URL,
		external: true,
		icon: '<svg viewBox="0 0 16 16" aria-hidden="true" width="18" height="18"><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path></svg>',
	},
	{
		label: 'RSS 订阅',
		href: '/rss.xml',
		external: false,
		icon: '<svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"></path><path d="M4 4a16 16 0 0 1 16 16"></path><circle cx="5" cy="19" r="1"></circle></svg>',
	},
	{
		label: '永劫无间数据平台',
		href: 'https://yjwj.pro',
		external: true,
		icon: '<svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>',
	},
	{
		label: '摸金战绩查询',
		href: 'https://naraka.yjwj.pro',
		external: true,
		icon: '<svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>',
	},
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<img
					class="avatar"
					src="https://github.com/yjwjsjz.png?size=240"
					alt="WuhuKaitou 的头像"
					width="112"
					height="112"
					loading="eager"
					referrerpolicy="no-referrer"
				/>
				<h1 class="greet">你好,我是 <span class="me">WuhuKaitou</span> <span class="wave" aria-hidden="true">👋</span></h1>
				<p class="line2">
					我把<em>游戏数据</em>铸成产品
					<span class="chip">✦ Bot & Web</span>
				</p>
				<p class="sub">A solo full-stack developer · bots, sites and data products.</p>
				<div class="hero-tail">
					<p class="motto">「先跑起来,再做漂亮。」</p>
					<p class="stats">{allPosts.length} 篇 · {wanzi} 万字 · {days} 天</p>
					<div class="socials">
						{
							socials.map((s) => (
								<a
									class="social-btn"
									href={s.href}
									target={s.external ? '_blank' : undefined}
									rel={s.external ? 'noopener' : undefined}
								>
									<span class="sr-only">{s.label}</span>
									<Fragment set:html={s.icon} />
								</a>
							))
						}
					</div>
				</div>
			</section>

			<section class="block">
				<div class="section-head">
					<h2>最新文章</h2>
					<a class="more" href="/blog">全部文章 →</a>
				</div>
				<ol class="post-list">
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<p class="post-meta">
										<FormattedDate date={post.data.pubDate} /> · 约{' '}
										{readingMinutes(post.body ?? '')} 分钟读完
									</p>
									<h3>{post.data.title}</h3>
									<p class="post-desc">{post.data.description}</p>
								</a>
							</li>
						))
					}
				</ol>
			</section>

			<section class="block">
				<div class="section-head">
					<h2>我在做什么</h2>
				</div>
				<div class="projects">
					{
						projects.map((p) => (
							<a
								class="project-card"
								href={p.href}
								target="_blank"
								rel="noopener"
								style={`--card-accent-light: ${p.colorLight}; --card-accent-dark: ${p.colorDark}`}
							>
								<span class="card-icon" aria-hidden="true">
									<Fragment set:html={p.icon} />
								</span>
								<h3>{p.name}</h3>
								<p>{p.desc}</p>
								<span class="link-hint">
									{p.hint} <span class="arrow">→</span>
								</span>
							</a>
						))
					}
				</div>
			</section>

			<section class="block">
				<div class="section-head">
					<h2>技术栈</h2>
				</div>
				<div class="stack-groups">
					{
						stacks.map((group) => (
							<div class="stack-group">
								<span class="stack-label">{group.label}</span>
								<ul class="stack">
									{group.items.map((item) => (
										<li>
											<span
												class="stack-dot"
												style={`background: ${group.color}`}
												aria-hidden="true"
											/>
											{item}
										</li>
									))}
								</ul>
							</div>
						))
					}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	/* ---- Hero(innei 式:全屏居中) ---- */
	.hero {
		min-height: calc(100svh - 6.5rem);
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		text-align: center;
		padding: 1em 0 2em;
	}
	.avatar {
		border-radius: 50%;
		border: 1px solid rgba(var(--gray-light), 0.9);
		box-shadow: 0 0 44px rgba(var(--gray), 0.35);
		margin-bottom: 1.1em;
	}
	.greet {
		margin: 0 0 0.15em;
		font-size: clamp(1.9em, 5.5vw, 2.8em);
		color: rgb(var(--black));
		font-weight: 700;
	}
	.me {
		color: var(--accent-text, var(--accent));
	}
	.wave {
		display: inline-block;
		transform-origin: 70% 70%;
	}
	.line2 {
		margin: 0 0 0.6em;
		font-size: clamp(1.3em, 3.8vw, 1.9em);
		color: rgb(var(--black));
		font-weight: 600;
	}
	.line2 em {
		font-style: italic;
		font-family: Georgia, '宋体', SimSun, serif;
		color: var(--accent-text, var(--accent));
		padding: 0 0.12em;
	}
	.chip {
		display: inline-block;
		vertical-align: 0.25em;
		margin-left: 0.3em;
		padding: 0.22em 0.75em;
		font-family: Consolas, 'Courier New', monospace;
		font-size: 0.5em;
		font-weight: 700;
		letter-spacing: 0.04em;
		color: var(--accent-text, var(--accent));
		border: 1px solid var(--accent-text, var(--accent));
		border-radius: 999px;
	}
	.sub {
		margin: 0;
		font-size: 0.78em;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: rgb(var(--gray));
	}
	.hero-tail {
		margin-top: clamp(2.5em, 12vh, 7em);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.6em;
	}
	.motto {
		margin: 0;
		font-family: Georgia, '宋体', SimSun, serif;
		font-style: italic;
		font-size: 0.95em;
		color: rgb(var(--gray));
	}
	.stats {
		margin: 0;
		font-size: 0.82em;
		color: rgb(var(--gray));
		font-variant-numeric: tabular-nums;
	}
	.socials {
		display: flex;
		gap: 0.65em;
		margin-top: 0.4em;
	}
	.social-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		border-radius: 50%;
		border: 1px solid rgba(var(--gray-light), 0.9);
		color: rgb(var(--gray-dark));
		background: var(--bg-surface);
		transition:
			color 0.15s ease,
			border-color 0.15s ease,
			transform 0.15s ease;
	}
	.social-btn:hover {
		color: var(--accent-text, var(--accent));
		border-color: rgb(var(--gray));
		transform: translateY(-2px);
	}

	/* ---- 区块通用 ---- */
	.block {
		margin-top: 2.5em;
	}
	.section-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1em;
		margin-bottom: 0.9em;
	}
	.section-head h2 {
		display: flex;
		align-items: center;
		gap: 0.45em;
		margin: 0;
		font-size: 1.55em;
	}
	.section-head h2::before {
		content: '';
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: var(--accent);
	}
	.more {
		font-size: 0.95em;
		font-weight: 600;
		text-decoration: none;
		white-space: nowrap;
	}
	.more:hover {
		text-decoration: underline;
	}

	/* ---- 最新文章 ---- */
	.post-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.post-list li + li {
		border-top: 1px solid rgb(var(--gray-light));
	}
	.post-list a {
		display: block;
		padding: 1em 0.9em;
		border-radius: 12px;
		text-decoration: none;
		transition: background-color 0.15s ease;
	}
	.post-list a:hover {
		background: rgba(var(--gray-light), 0.45);
	}
	.post-meta {
		margin: 0 0 0.25em;
		font-size: 0.85em;
		color: rgb(var(--gray));
	}
	.post-list h3 {
		margin: 0 0 0.25em;
		font-size: 1.2em;
		color: rgb(var(--black));
	}
	.post-list a:hover h3 {
		color: var(--accent-text, var(--accent));
	}
	.post-desc {
		margin: 0;
		font-size: 0.92em;
		color: rgb(var(--gray-dark));
	}

	/* ---- 项目卡片 ---- */
	.projects {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 1em;
	}
	.card-icon {
		display: grid;
		place-items: center;
		width: 40px;
		height: 40px;
		margin-bottom: 0.7em;
		border-radius: 10px;
		background: rgba(var(--gray-light), 0.6);
		color: var(--card-accent, var(--accent));
	}
	.project-card {
		/* 亮色默认用深色系,暗色主题下切换为亮色系(见下方主题覆盖) */
		--card-accent: var(--card-accent-light, var(--accent));
		position: relative;
		overflow: hidden;
		display: block;
		padding: 1.25em;
		border: 1px solid rgba(var(--gray-light), 0.8);
		border-radius: 16px;
		text-decoration: none;
		color: inherit;
		background: var(--bg-surface);
		transition:
			box-shadow 0.2s ease,
			transform 0.2s ease,
			background-color 0.2s ease;
	}
	.project-card:hover {
		box-shadow: 0 8px 28px rgba(var(--gray), 0.22);
		transform: translateY(-3px);
	}
	.project-card h3 {
		margin: 0.2em 0 0.4em;
		font-size: 1.15em;
		color: rgb(var(--black));
	}
	.project-card p {
		margin: 0 0 0.6em;
		font-size: 0.92em;
		color: rgb(var(--gray-dark));
	}
	.link-hint {
		font-size: 0.9em;
		font-weight: 600;
		color: var(--card-accent, var(--accent));
	}
	.arrow {
		display: inline-block;
		transition: transform 0.2s ease;
	}
	.project-card:hover .arrow {
		transform: translateX(4px);
	}
	:global([data-theme='dark']) .project-card {
		--card-accent: var(--card-accent-dark, var(--accent));
	}
	@media (prefers-color-scheme: dark) {
		:global(:root:not([data-theme='light'])) .project-card {
			--card-accent: var(--card-accent-dark, var(--accent));
		}
	}

	/* ---- 技术栈 ---- */
	.stack-groups {
		display: flex;
		flex-direction: column;
		gap: 0.9em;
	}
	.stack-group {
		display: flex;
		align-items: baseline;
		gap: 0.9em;
	}
	.stack-label {
		flex: 0 0 3em;
		font-size: 0.88em;
		font-weight: 700;
		color: rgb(var(--gray));
	}
	.stack {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.6em;
	}
	.stack li {
		display: inline-flex;
		align-items: center;
		gap: 0.45em;
		padding: 0.3em 0.85em;
		border-radius: 999px;
		background: rgba(var(--gray-light), 0.75);
		border: 1px solid rgb(var(--gray-light));
		font-size: 0.88em;
		color: rgb(var(--gray-dark));
		transition:
			transform 0.15s ease,
			border-color 0.15s ease;
	}
	.stack li:hover {
		transform: translateY(-1px);
		border-color: rgb(var(--gray));
	}
	.stack-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		flex: none;
	}
	@media (max-width: 560px) {
		.stack-group {
			flex-direction: column;
			gap: 0.4em;
		}
		.stack-label {
			flex: none;
		}
	}

	/* ---- 入场动效(尊重减动效偏好) ---- */
	@media (prefers-reduced-motion: no-preference) {
		.hero > * {
			animation: rise 0.55s ease both;
		}
		.hero > :nth-child(2) {
			animation-delay: 0.06s;
		}
		.hero > :nth-child(3) {
			animation-delay: 0.12s;
		}
		.hero > :nth-child(4) {
			animation-delay: 0.18s;
		}
		.hero > :nth-child(5) {
			animation-delay: 0.24s;
		}
		.greet:hover .wave {
			animation: wave 0.9s ease-in-out;
		}
	}
	@keyframes rise {
		from {
			opacity: 0;
			transform: translateY(12px);
		}
		to {
			opacity: 1;
			transform: none;
		}
	}
	@keyframes wave {
		0%,
		100% {
			transform: rotate(0deg);
		}
		25% {
			transform: rotate(18deg);
		}
		50% {
			transform: rotate(-8deg);
		}
		75% {
			transform: rotate(12deg);
		}
	}
</style>
