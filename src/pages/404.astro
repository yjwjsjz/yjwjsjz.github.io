---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`404 · ${SITE_TITLE}`} description="页面不存在" />
	</head>
	<body>
		<Header />
		<main class="not-found">
			<p class="code">404</p>
			<h1>这一页不存在</h1>
			<p>可能是链接拼错了,也可能是这篇内容已经搬家。</p>
			<p class="links"><a href="/">回首页</a> · <a href="/blog">看看文章</a></p>
		</main>
		<Footer />
	</body>
</html>

<style>
	.not-found {
		text-align: center;
		padding: 5em 1em 7em;
	}
	.code {
		font-size: 6em;
		font-weight: 700;
		line-height: 1;
		margin: 0 0 0.2em;
		color: var(--accent-text, var(--accent));
		font-family: Consolas, 'Courier New', monospace;
	}
	.links a {
		font-weight: 600;
	}
</style>
