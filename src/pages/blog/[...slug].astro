---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = (await getCollection('blog')).sort(
		(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
	);
	return posts.map((post, i) => ({
		params: { slug: post.id },
		props: {
			post,
			// 列表按时间倒序:上一篇 = 更早的一篇,下一篇 = 更新的一篇
			nextPost: i > 0 ? { slug: posts[i - 1].id, title: posts[i - 1].data.title } : null,
			prevPost:
				i < posts.length - 1 ? { slug: posts[i + 1].id, title: posts[i + 1].data.title } : null,
		},
	}));
}

type PostLink = { slug: string; title: string };
type Props = {
	post: CollectionEntry<'blog'>;
	prevPost: PostLink | null;
	nextPost: PostLink | null;
};

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);

// 中文按 400 字/分钟,英文按 200 词/分钟估算
const body = post.body ?? '';
const cjkChars = (body.match(/[一-鿿]/g) ?? []).length;
const latinWords = body
	.replace(/[一-鿿]/g, ' ')
	.split(/\s+/)
	.filter(Boolean).length;
const minutes = Math.max(1, Math.round(cjkChars / 400 + latinWords / 200));
---

<BlogPost {...post.data} minutes={minutes} prevPost={prevPost} nextPost={nextPost} showComments>
	<Content />
</BlogPost>
