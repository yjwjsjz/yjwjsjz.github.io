---
import Comments from '../components/Comments.astro';
import Page from '../layouts/Page.astro';
---

<Page title="留言板 · WuhuKaitou 的博客" description="路过打个招呼,交换友链也在这里">
	<h1 class="page-title">留言板</h1>
	<p class="page-desc">
		路过的朋友,说点什么再走吧——吐槽、建议、交换友链、或者只是打个招呼都行。
		登录 GitHub 账号即可留言。
	</p>
	<Comments />
</Page>

<style>
	.page-title {
		margin: 0.6em 0 0.2em;
	}
	.page-desc {
		margin: 0 0 1em;
		color: rgb(var(--gray));
	}
</style>
